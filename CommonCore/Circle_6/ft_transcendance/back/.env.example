NODE_ENV=development
PORT=3001

# --- Vault Configuration (AppRole Authentication) ---
# These are set automatically by docker-compose from vault-init container:
# - VAULT_ADDR: http://ft_vault:8200
# - VAULT_ROLE_ID_FILE: /vault/init/back-role-id
# - VAULT_SECRET_ID_FILE: /vault/init/back-secret-id

# --- Fallback values (used if Vault is unavailable) ---
# In production with Vault running, these are NOT used
DB_USER=transcendance
DB_HOST=db
DB_NAME=transcendance_db
DB_PASSWORD=password
DB_PORT=5432
ADMIN_USER=admin
ADMIN_PASSWORD=admin_password